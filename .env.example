# Copy to `.env.local` and fill in. Never commit `.env.local`.

# --- Better Auth (required) ---
# openssl rand -base64 32
# BETTER_AUTH_SECRET="..."
# BETTER_AUTH_URL=http://localhost:3000

# Optional OAuth (enable Google and/or GitHub when both id + secret are set).
# Redirect / authorized callback URL (add in each provider’s console):
#   {BETTER_AUTH_URL}/api/auth/callback/google
#   {BETTER_AUTH_URL}/api/auth/callback/github
# GOOGLE_CLIENT_ID=...
# GOOGLE_CLIENT_SECRET=...
# GITHUB_CLIENT_ID=...
# GITHUB_CLIENT_SECRET=...

# Optional: `npm run ensure:director-auth` (legacy mock profile + Better Auth login)
# DIRECTOR_DEV_EMAIL=director@local.dev
# DIRECTOR_DEV_PASSWORD=DirectorDev-local!
# DIRECTOR_DEV_NAME=Local Director

# --- Required for local dev (Prisma) ---
# Use a local Postgres or a hosted URL (e.g. Supabase pooler for DATABASE_URL,
# direct host for DIRECT_URL when migrations need a non-pooled connection).
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"
# DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

# After setting DATABASE_URL:
#   npx prisma migrate dev
#   # or: npx prisma db push

# --- Optional: Stable Audio (generation provider) ---
# Restart `npm run dev` after changing so next.config can expose NEXT_PUBLIC_HAS_STABILITY_KEY.
# STABILITY_API_KEY=sk-...

# --- Optional: Lyria 3 / Gemini API (generation provider) ---
# Get an API key at https://aistudio.google.com/apikey
# Select "Lyria 3 (Google)" in project settings to use this provider.
# GEMINI_API_KEY=...

# Base URL for invite/brief links in emails and API responses (defaults work on Vercel via VERCEL_URL).
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Optional: Resend (transactional email) ---
# When RESEND_API_KEY and RESEND_FROM are set, project invites and (by default) brief-ready
# notifications are emailed. Verify your domain in Resend; from must use that domain in production.
# RESEND_API_KEY=re_...
# RESEND_FROM="Leitmotif <onboarding@resend.dev>"   # or Briefs <briefs@yourdomain.com>
# RESEND_REPLY_TO=you@yourdomain.com              # optional
# Set to 0/false/no to skip brief-ready emails while keeping invite emails:
# RESEND_BRIEF_EMAILS=true

# --- Optional: Inngest (durable mock-cue generation queue) ---
# When INNGEST_EVENT_KEY is set, POST /api/scenes/[id]/generate queues work on Inngest.
# Sync the app URL in the Inngest dashboard; serve path is /api/inngest
# INNGEST_EVENT_KEY=...
# INNGEST_SIGNING_KEY=...

# --- Optional: LAN dev (Next.js 16+) ---
# If you open the app at http://<your-LAN-IP>:3000 instead of localhost, set this
# to that IP (comma-separated for several). Restart `npm run dev` after changing.
# Defaults to 192.168.1.237 in next.config.ts when unset — override if your IP differs.
# NEXT_DEV_ALLOWED_ORIGINS=192.168.1.100

# --- Cloudflare R2 (file storage) ---
# Required in production. Without these, files are stored on local disk (.data/uploads/).
# Create an R2 bucket + API token at https://dash.cloudflare.com → R2.
# Scene video uploads use a presigned PUT to R2 when these are set — add bucket CORS rules:
#   Allowed origins: your app (e.g. https://www.theleitmotif.com, http://localhost:3000)
#   Allowed methods: PUT, GET, HEAD
#   Allowed headers: Content-Type
# R2_ACCOUNT_ID=your_account_id
# R2_ACCESS_KEY_ID=your_access_key
# R2_SECRET_ACCESS_KEY=your_secret_key
# R2_BUCKET_NAME=leitmotif-uploads
# Optional: public CDN hostname for R2 (not required for in-app playback — URLs use /api/files).
# R2_PUBLIC_URL=https://files.theleitmotif.com
