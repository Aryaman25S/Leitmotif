# Copy to `.env.local` and fill in. Never commit `.env.local`.

# --- Required for local dev (Prisma) ---
# Use a local Postgres or a hosted URL (e.g. Supabase pooler for DATABASE_URL,
# direct host for DIRECT_URL when migrations need a non-pooled connection).
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"
# DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

# After setting DATABASE_URL:
#   npx prisma migrate dev
#   # or: npx prisma db push

# --- Optional: Stable Audio ---
# Restart `npm run dev` after changing so next.config can expose NEXT_PUBLIC_HAS_STABILITY_KEY.
# STABILITY_API_KEY=sk-...

# Base URL for magic invite links (defaults work for localhost if unset).
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Optional: Inngest (durable mock-cue generation queue) ---
# When INNGEST_EVENT_KEY is set, POST /api/scenes/[id]/generate queues work on Inngest.
# Sync the app URL in the Inngest dashboard; serve path is /api/inngest
# INNGEST_EVENT_KEY=...
# INNGEST_SIGNING_KEY=...

# --- Optional: LAN dev (Next.js 16+) ---
# If you open the app at http://<your-LAN-IP>:3000 instead of localhost, set this
# to that IP (comma-separated for several). Restart `npm run dev` after changing.
# Defaults to 192.168.1.237 in next.config.ts when unset — override if your IP differs.
# NEXT_DEV_ALLOWED_ORIGINS=192.168.1.100

# --- Cloudflare R2 (file storage) ---
# Required in production. Without these, files are stored on local disk (.data/uploads/).
# Create an R2 bucket + API token at https://dash.cloudflare.com → R2.
# R2_ACCOUNT_ID=your_account_id
# R2_ACCESS_KEY_ID=your_access_key
# R2_SECRET_ACCESS_KEY=your_secret_key
# R2_BUCKET_NAME=leitmotif-uploads
# Optional: public CDN hostname for R2 (not required for in-app playback — URLs use /api/files).
# R2_PUBLIC_URL=https://files.theleitmotif.com
